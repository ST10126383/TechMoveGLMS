@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Edit Contract
                    </h3>
                </div>

                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <!-- Client Selection -->
                        <div class="mb-3">
                            <label asp-for="ClientId" class="form-label fw-bold"></label>
                            <select asp-for="ClientId" asp-items="ViewBag.ClientId"
                                    class="form-select">
                                <option value="">-- Select Client --</option>
                            </select>
                            <span asp-validation-for="ClientId" class="text-danger"></span>
                        </div>

                        <!-- Service Level -->
                        <div class="mb-3">
                            <label asp-for="ServiceLevel" class="form-label fw-bold"></label>
                            <input asp-for="ServiceLevel" class="form-control" placeholder="e.g. Premium, Standard, Basic" />
                            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                        </div>

                        <!-- Dates Row -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-bold"></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-bold"></label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-bold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Draft">Draft</option>
                                <option value="Active">Active</option>
                                <option value="On Hold">On Hold</option>
                                <option value="Expired">Expired</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Box -->
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h6 class="text-muted">Note</h6>
                    <p class="small text-muted mb-0">
                        Changing the status to <strong>Expired</strong> or <strong>On Hold</strong> will prevent
                        creation of new Service Requests for this contract.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-trash"></i> Delete Contract
                    </h3>
                </div>

                <div class="card-body">
                    <div class="alert alert-danger">
                        <h5>Are you sure you want to delete this contract?</h5>
                        <p class="mb-0">This action cannot be undone.</p>
                    </div>

                    <h5 class="mb-3">Contract Information</h5>
                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Contract ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4 fw-bold">Client</dt>
                        <dd class="col-sm-8">
                            <strong>@Model.Client?.Name</strong><br />
                            <small class="text-muted">@Model.Client?.ContactEmail</small>
                        </dd>

                        <dt class="col-sm-4 fw-bold">Service Level</dt>
                        <dd class="col-sm-8">@Model.ServiceLevel</dd>

                        <dt class="col-sm-4 fw-bold">Period</dt>
                        <dd class="col-sm-8">
                            @Model.StartDate.ToShortDateString() — @Model.EndDate.ToShortDateString()
                        </dd>

                        <dt class="col-sm-4 fw-bold">Status</dt>
                        <dd class="col-sm-8">
                            @{
                                string badgeClass = Model.Status switch
                                {
                                    "Active" => "bg-success",
                                    "Expired" => "bg-danger",
                                    "On Hold" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@Model.Status</span>
                        </dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary me-md-2 px-4">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-danger px-4"
                                    onclick="return confirm('This action is irreversible. Are you absolutely sure?');">
                                <i class="bi bi-trash"></i> Yes, Delete Contract
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-warning mt-4">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Warning:</strong> Deleting this contract will also remove all associated Service Requests and uploaded files.
            </div>

        </div>
    </div>
</div>
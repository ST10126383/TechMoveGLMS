@model TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Create New Contract";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">

            <div class="card shadow">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="mb-0">
                        <i class="bi bi-file-earmark-text me-2"></i>Create New Contract
                    </h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Client -->
                        <div class="mb-4">
                            <label asp-for="ClientId" class="form-label fw-bold"></label>
                            <select asp-for="ClientId" asp-items="ViewBag.ClientId"
                                    class="form-select form-select-lg">
                                <option value="">-- Select a Client --</option>
                            </select>
                            <span asp-validation-for="ClientId" class="text-danger"></span>
                        </div>

                        <!-- Service Level - Improved Dropdown -->
                        <div class="mb-4">
                            <label asp-for="ServiceLevel" class="form-label fw-bold"></label>
                            <select asp-for="ServiceLevel" class="form-select form-select-lg">
                                <option value="">-- Select Service Level --</option>
                                <option value="Basic">Basic</option>
                                <option value="Standard">Standard</option>
                                <option value="Premium">Premium</option>
                                <option value="Enterprise">Enterprise</option>
                                <option value="Platinum">Platinum</option>
                                <option value="Custom">Custom / Other</option>
                            </select>
                            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                        </div>

                        <!-- Contract Period -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label fw-bold"></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label fw-bold"></label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="mb-5">
                            <label asp-for="Status" class="form-label fw-bold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Draft">Draft</option>
                                <option value="Active">Active</option>
                                <option value="On Hold">On Hold</option>
                                <option value="Expired">Expired</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-plus-circle me-2"></i>
                                Create Contract
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tips -->
            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h6 class="text-muted mb-3">💡 Important Notes</h6>
                    <ul class="small text-muted">
                        <li><strong>Start Date</strong> must be before <strong>End Date</strong></li>
                        <li>Upload the Signed Agreement PDF after creating the contract (from Details page)</li>
                        <li>Contracts with status <strong>Expired</strong> or <strong>On Hold</strong> cannot have new Service Requests</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
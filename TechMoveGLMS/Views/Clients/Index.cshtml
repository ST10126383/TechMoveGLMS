@model IEnumerable<TechMoveGLMS.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="container py-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Client Directory</h2>
            <p class="text-muted small mb-0">Manage your active client list and contact details.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Add New Client
        </a>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.ContactEmail)</th>
                        <th>@Html.DisplayNameFor(model => model.ContactPhone)</th>
                        <th>@Html.DisplayNameFor(model => model.Region)</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.Name)</span>
                            </td>
                            <td>
                                <a href="mailto:@item.ContactEmail" class="text-decoration-none">
                                    @Html.DisplayFor(modelItem => item.ContactEmail)
                                </a>
                            </td>
                            <td>
                                <span class="text-muted">@Html.DisplayFor(modelItem => item.ContactPhone)</span>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark opacity-75">@Html.DisplayFor(modelItem => item.Region)</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="card-body text-center py-5">
                <i class="bi bi-people text-muted mb-3" style="font-size: 3rem;"></i>
                <p class="text-muted">No clients found in the database.</p>
            </div>
        }
    </div>
</div>
@model TechMoveGLMS.Models.ContractFile

@{
    ViewData["Title"] = "Edit Document Properties";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-7">

            <!-- Breadcrumb Navigation -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Documents</a></li>
                    <li class="breadcrumb-item active">Edit Properties</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center">
                        <div class="p-2 bg-primary-subtle rounded me-3">
                            <i class="bi bi-file-earmark-diff text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Update File Record</h5>
                            <small class="text-muted">ID: @Model.Id &bull; @Model.FileName</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <!-- File Naming Section -->
                            <div class="col-12">
                                <label asp-for="FileName" class="form-label fw-bold small text-uppercase tracking-wider text-muted"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-muted"><i class="bi bi-tag"></i></span>
                                    <input asp-for="FileName" class="form-control" placeholder="Filename.pdf" />
                                </div>
                                <span asp-validation-for="FileName" class="text-danger small"></span>
                            </div>

                            <!-- Association Section -->
                            <div class="col-md-12">
                                <label asp-for="ContractId" class="form-label fw-bold small text-uppercase tracking-wider text-muted">Linked Contract Reference</label>
                                <select asp-for="ContractId" class="form-select border-primary-subtle" asp-items="ViewBag.ContractId"></select>
                                <span asp-validation-for="ContractId" class="text-danger small"></span>
                                <div class="form-text mt-1">Changing this moves the document association to a different contract.</div>
                            </div>

                            <!-- Technical Details -->
                            <div class="col-12">
                                <label asp-for="FilePath" class="form-label fw-bold small text-uppercase tracking-wider text-muted"></label>
                                <input asp-for="FilePath" class="form-control bg-light" />
                                <span asp-validation-for="FilePath" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="UploadedDate" class="form-label fw-bold small text-uppercase tracking-wider text-muted"></label>
                                <input asp-for="UploadedDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="UploadedDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-5" />

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none px-0">
                                <i class="bi bi-x-circle me-1"></i> Discard Changes
                            </a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                                <i class="bi bi-check2-circle me-1"></i> Update Properties
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Warning Box -->
            <div class="mt-4 border-start border-4 border-warning bg-warning-subtle p-3 rounded-end">
                <div class="d-flex">
                    <i class="bi bi-exclamation-triangle text-warning me-3"></i>
                    <p class="mb-0 small text-dark-emphasis">
                        <strong>Note:</strong> Modifying the <em>File Path</em> does not move the physical file on the server. Ensure the new path accurately reflects the document's location.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
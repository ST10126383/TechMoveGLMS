@model TechMoveGLMS.Models.ContractFile

@{
    ViewData["Title"] = "File Details";
}

<div class="container py-4">
    <!-- Top Navigation & Title -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Documents</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-0 text-dark">Document Information</h2>
        </div>
        <div class="btn-group">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-primary shadow-sm">
                <i class="bi bi-pencil me-1"></i> Edit Details
            </a>
            <a asp-action="Index" class="btn btn-light border shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Details Card -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0 fw-bold"><i class="bi bi-file-earmark-text me-2 text-primary"></i>File Metadata</h5>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-3 text-muted fw-normal mb-3">File Name</dt>
                        <dd class="col-sm-9 fw-bold mb-3">@Html.DisplayFor(model => model.FileName)</dd>

                        <dt class="col-sm-3 text-muted fw-normal mb-3">Storage Path</dt>
                        <dd class="col-sm-9 mb-3">
                            <code class="bg-light p-2 rounded border d-inline-block text-break">@Html.DisplayFor(model => model.FilePath)</code>
                        </dd>

                        <dt class="col-sm-3 text-muted fw-normal mb-3">Upload Date</dt>
                        <dd class="col-sm-9 mb-3">
                            <span class="text-secondary"><i class="bi bi-calendar3 me-2"></i>@Html.DisplayFor(model => model.UploadedDate)</span>
                        </dd>

                        <dt class="col-sm-3 text-muted fw-normal mb-0">Associated Contract</dt>
                        <dd class="col-sm-9 mb-0">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                                <i class="bi bi-link-45deg me-1"></i> @Html.DisplayFor(model => model.Contract.ServiceLevel)
                            </span>
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-light p-3 border-0">
                    <div class="d-flex align-items-center text-muted small">
                        <i class="bi bi-shield-check me-2 text-success"></i> Securely stored in document repository
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar / Actions -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 bg-primary text-white mb-4">
                <div class="card-body text-center py-4">
                    <i class="bi bi-file-pdf display-4 mb-3"></i>
                    <h5>Quick Access</h5>
                    <p class="small opacity-75">View or download the physical file associated with this record.</p>
                    <div class="d-grid gap-2">
                        <a href="@Model.FilePath" target="_blank" class="btn btn-light fw-bold text-primary">
                            <i class="bi bi-box-arrow-up-right me-1"></i> Open File
                        </a>
                        <a href="@Model.FilePath" download class="btn btn-primary border-white fw-bold">
                            <i class="bi bi-download me-1"></i> Download
                        </a>
                    </div>
                </div>
            </div>

            <!-- Audit Trail (Simulated) -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-3">
                    <h6 class="fw-bold small mb-3 text-uppercase text-muted">System Info</h6>
                    <div class="small">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Record ID:</span>
                            <span class="text-dark fw-bold">@Model.Id</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Type:</span>
                            <span class="text-dark fw-bold">Contract Document</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
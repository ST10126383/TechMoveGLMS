@model TechMoveGLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Request Details";

    // Logic for Status Badge Color
    string statusClass = Model.Status switch
    {
        "Completed" => "bg-success",
        "In Progress" => "bg-primary",
        "Pending" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="container py-4">
    <!-- Header with Breadcrumbs -->
    <div class="row mb-4">
        <div class="col d-flex justify-content-between align-items-center">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Service Requests</a></li>
                        <li class="breadcrumb-item active">Request #@Model.Id</li>
                    </ol>
                </nav>
                <h2 class="fw-bold mb-0">Service Request Details</h2>
            </div>
            <div class="btn-group">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-light border">
                    <i class="bi bi-list me-1"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Content Column -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-muted mb-4 text-uppercase small tracking-wider">Description</h5>
                    <div class="p-4 bg-light rounded-3 mb-4">
                        <p class="lead mb-0 text-dark">@Html.DisplayFor(model => model.Description)</p>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-muted small text-uppercase mb-3">Linked Contract</h6>
                            <p class="mb-0">
                                <i class="bi bi-file-earmark-text me-2"></i>
                                <span class="fw-bold">@Html.DisplayFor(model => model.Contract.ServiceLevel)</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-muted small text-uppercase mb-3">Submission Date</h6>
                            <p class="mb-0">
                                <i class="bi bi-calendar-event me-2"></i>
                                @Html.DisplayFor(model => model.CreatedDate)
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Summary Column -->
        <div class="col-lg-4">
            <!-- Status Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center py-4">
                    <h6 class="text-muted small text-uppercase fw-bold mb-3">Request Status</h6>
                    <span class="badge @statusClass rounded-pill px-4 py-2 fs-6 shadow-sm">
                        @Html.DisplayFor(model => model.Status)
                    </span>
                </div>
            </div>

            <!-- Cost Summary Card -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-currency-exchange me-2 text-primary"></i>Financial Summary</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Total USD</span>
                        <h4 class="mb-0 fw-bold text-success">$@Html.DisplayFor(model => model.CostUSD)</h4>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Total ZAR</span>
                        <h4 class="mb-0 fw-bold text-primary">R@Html.DisplayFor(model => model.CostZAR)</h4>
                    </div>
                </div>
                <div class="card-footer bg-light border-0 py-3">
                    <div class="d-grid">
                        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
                            <i class="bi bi-printer me-1"></i> Print Invoice
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
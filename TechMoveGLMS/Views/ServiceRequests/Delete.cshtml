@model TechMoveGLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-7">

            <!-- Warning Alert -->
            <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-octagon fs-2 me-3"></i>
                <div>
                    <h4 class="alert-heading mb-1 fw-bold">Permanent Deletion</h4>
                    <p class="mb-0">Are you sure you want to delete this service request? All cost data and logs will be purged.</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="card-title mb-0 d-flex justify-content-between align-items-center">
                        Request Details
                        <span class="badge bg-warning text-dark">@Html.DisplayFor(model => model.Status)</span>
                    </h5>
                </div>

                <div class="card-body p-4 p-md-5">
                    <dl class="row mb-0">
                        <!-- Contract Info -->
                        <dt class="col-sm-4 text-muted mb-3 text-uppercase small tracking-wider">Contract Reference</dt>
                        <dd class="col-sm-8 mb-3 fw-bold">@Html.DisplayFor(model => model.Contract.ServiceLevel)</dd>

                        <!-- Description -->
                        <dt class="col-sm-4 text-muted mb-3 text-uppercase small tracking-wider">Description</dt>
                        <dd class="col-sm-8 mb-3 text-dark bg-light p-3 rounded border-start border-4">
                            @Html.DisplayFor(model => model.Description)
                        </dd>

                        <!-- Financials -->
                        <dt class="col-sm-4 text-muted mb-3 text-uppercase small tracking-wider">Cost (USD)</dt>
                        <dd class="col-sm-8 mb-3 text-danger fw-bold">$ @Html.DisplayFor(model => model.CostUSD)</dd>

                        <dt class="col-sm-4 text-muted mb-3 text-uppercase small tracking-wider">Cost (ZAR)</dt>
                        <dd class="col-sm-8 mb-3 text-danger fw-bold">R @Html.DisplayFor(model => model.CostZAR)</dd>

                        <!-- Date -->
                        <dt class="col-sm-4 text-muted mb-0 text-uppercase small tracking-wider">Date Created</dt>
                        <dd class="col-sm-8 mb-0">@Html.DisplayFor(model => model.CreatedDate)</dd>
                    </dl>
                </div>

                <div class="card-footer bg-light p-4">
                    <form asp-action="Delete" class="d-flex justify-content-between align-items-center">
                        <input type="hidden" asp-for="Id" />

                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>

                        <button type="submit" class="btn btn-danger px-5 fw-bold shadow">
                            <i class="bi bi-trash3 me-1"></i> Delete Request
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
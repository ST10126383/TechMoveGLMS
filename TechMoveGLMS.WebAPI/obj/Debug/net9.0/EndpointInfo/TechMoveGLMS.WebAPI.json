  "components": {
    "schemas": {
      "Client": {
        "required": [
          "contactEmail",
          "contactPhone",
          "name",
          "region"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "contactEmail": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "contactPhone": {
            "minLength": 1,
            "type": "string",
            "format": "tel"
          },
          "region": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "contracts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contract"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Contract": {
        "required": [
          "clientId",
          "endDate",
          "serviceLevel",
          "startDate",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "client": {
            "$ref": "#/components/schemas/Client"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "serviceLevel": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "serviceRequests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServiceRequest"
            },
            "nullable": true
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContractFile"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ContractFile": {
        "required": [
          "contractId",
          "fileName",
          "filePath"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "contractId": {
            "type": "integer",
            "format": "int32"
          },
          "contract": {
            "$ref": "#/components/schemas/Contract"
          },
          "fileName": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "filePath": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          },
          "uploadedDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "LoginModel": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ServiceRequest": {
        "required": [
          "contractId",
          "costUSD",
          "description",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "contractId": {
            "type": "integer",
            "format": "int32"
          },
          "contract": {
            "$ref": "#/components/schemas/Contract"
          },
          "description": {
            "maxLength": 500,
            "minLength": 10,
            "type": "string"
          },
          "costUSD": {
            "maximum": 1000000,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "costZAR": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
